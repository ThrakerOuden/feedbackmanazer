@import "tailwindcss";

:root {
  color-scheme: light;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

html,
body,
#root {
  min-height: 100%;
}

body {
  margin: 0;
  background: #f6f7fb;
  color: #0f172a;
}

button,
input,
select,
textarea {
  font: inherit;
}
